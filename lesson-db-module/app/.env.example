# Sample environment variables for local runs (docker run / docker-compose).
# In Kubernetes these same variables live in the Helm ConfigMap
# (charts/django-app/values.yaml -> config) and are injected via envFrom.

# Django
DEBUG=1
SECRET_KEY=dev-insecure-secret-key-change-me
ALLOWED_HOSTS=*

# Database mode: 1 = SQLite (self contained, default), 0 = PostgreSQL
USE_SQLITE=1

# PostgreSQL (only used when USE_SQLITE=0 and POSTGRES_HOST is set)
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_HOST=
POSTGRES_PORT=5432
